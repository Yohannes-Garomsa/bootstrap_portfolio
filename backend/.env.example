NODE_ENV=development
PORT=5000
CLIENT_URL=http://127.0.0.1:5500
CLIENT_URLS=http://127.0.0.1:5500,http://localhost:5500
REQUEST_BODY_LIMIT=10kb
MONGODB_URI=mongodb://127.0.0.1:27017/portfolio_contact
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
MAIL_FROM=Portfolio Contact <your-email@example.com>
CONTACT_RECEIVER_EMAIL=your-email@example.com
ENABLE_AUTO_REPLY=true
